generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

model User {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  passwordHash String?
  avatarUrl String?
  role      Role       @default(VIEWER)
  status    UserStatus @default(INVITED)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}
